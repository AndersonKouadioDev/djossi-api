# Base de données — Neon (https://console.neon.tech)
# DATABASE_URL : URL poolée (host avec -pooler) — utilisée par l'app
# DIRECT_URL   : URL directe (host sans -pooler) — utilisée par prisma migrate
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# Serveur
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
# Origines CORS autorisées, séparées par des virgules ("*" en dev)
CORS_ORIGINS=*

# JWT
JWT_SECRET=change-me
JWT_ACCESS_TTL=15m
REGISTRATION_TOKEN_TTL=10m
REFRESH_TTL_DAYS=30

# OTP
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
# Accepte le code 123456 (mock de l'app Flutter) — true en dev uniquement
OTP_ACCEPT_DEV_CODE=true
# Désactive la limite 3 OTP/heure/numéro — true en dev uniquement
OTP_THROTTLE_DISABLED=true

# Intégrations mockées
WEBHOOK_SECRET=change-me
# Délai avant le webhook simulé du paiement mobile money (0 = synchrone, utile en test)
PAYMENT_MOCK_AUTOCOMPLETE_MS=3000
UPLOAD_DIR=./uploads

# Throttling global (requêtes / minute / IP)
THROTTLE_LIMIT=100

# Paiement — Wave Checkout
# Adaptateur actif : "mock" (dev) ou "wave" (vrais paiements). Garder "mock" en local.
PAYMENT_GATEWAY=mock
# Acompte fixe (FCFA) payé via Wave pour confirmer une réservation.
BOOKING_DEPOSIT_FCFA=2000
# Clé API Wave (dashboard Wave Business). NE JAMAIS committer la vraie valeur.
WAVE_API_KEY=
# Secret de signature des webhooks Wave.
WAVE_WEBHOOK_SECRET=
# Retours après paiement — URLs HTTPS sentinelles (exigées par Wave),
# interceptées par la webview de l'app.
WAVE_SUCCESS_URL=https://djossi.ci/payment/success
WAVE_ERROR_URL=https://djossi.ci/payment/error

# Stockage des fichiers (avatars, portfolio)
# Adaptateur actif : "local" (dev, disque servi sur /uploads) ou "s3" (objet
# S3-compatible : AWS S3, MinIO, Scaleway, Cloudflare R2…). Garder "local" en local.
STORAGE_DRIVER=local
# Variables S3 — requises UNIQUEMENT si STORAGE_DRIVER=s3.
# NE JAMAIS committer de vraies valeurs (placeholders ci-dessous).
# Endpoint S3 (ex. AWS: https://s3.eu-west-3.amazonaws.com ; MinIO: http://localhost:9000)
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET=

# Cache — Redis (optionnel). Si défini, cache distribué scalable ; sinon cache
# mémoire local. Ex : redis://localhost:6379 (ne pas committer de vraie URL).
REDIS_URL=
